{
    auto_https off
    http_port 8080
    https_port 8443
    admin 0.0.0.0:3003
    servers {
        metrics
    }
}
:8080 {
    root * /srv
    route {
        handle /srv/assets/*.js {
            header Cache-Control "no-cache, no-store"
            templates {
                mime application/javascript text/javascript
            }
            file_server
        }
        handle /srv/assets/* {
            file_server
        }
        handle {
            try_files {path} /index.html
            file_server
        }
    }
    encode zstd gzip
}
:3001 {
    handle /health {
        respond "OK"
    }
}
