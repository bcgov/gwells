{
    auto_https off
    http_port 8080
    https_port 8443
    admin 0.0.0.0:3003
    servers {
        metrics
    }
}
{$VITE_BACKEND_URL:http://backend:8000/} {
    root * app/frontend/dist
    file_server
    templates
}
:8080 {
    root * /srv
    encode zstd gzip
    file_server

    # Handle the double path prefix from OpenShift
    handle /gwells/* {
        # Strip the leading /gwells prefix from all incoming requests
        uri strip_prefix /gwells

        # Handle SPA routes, but avoid API paths
        @spa_router {
            not path /gwells/api/v2/*
            file {
                try_files {path} /index.html
            }
        }

        templates {
            mime application/javascript
            match /env.js
        }

        rewrite @spa_router {http.matchers.file.relative}
        
        # Forward API requests with the prefix handled
        reverse_proxy /api* {$VITE_BACKEND_URL} {
        }
    }
}
:3001 {
    handle /health {
        respond "OK"
    }
}
