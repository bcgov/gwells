{
	auto_https off
	http_port 8080
    https_port 8443
	admin 0.0.0.0:3003
	servers {
		metrics
	}
}
{$VITE_AXIOS_BASE_URL:http://backend:8000/} {
	root * app/frontend/dist
	file_server
	templates
}
:8080 {
	# log {
	# 	output stdout
	# 	format console {
	# 		time_format iso8601
	# 		level_format color
	# 	}
	# 	level {$LOG_LEVEL}
	# }
	root * /srv
	encode zstd gzip
	file_server
	@spa_router {
		not path /gwells/api/v2/*
		file {
			try_files {path} /index.html
		}
	}
	templates {
        mime application/javascript text/plain
        # match /env.js
    }
	replace "{{.Env.VITE_AXIOS_BASE_URL}}" {$VITE_AXIOS_BASE_URL}
	rewrite @spa_router {http.matchers.file.relative}
	# Proxy requests to API service
	reverse_proxy /api* {
		to $CADDY_HOST
	}
}
:3001 {
	handle /health {
		respond "OK"
	}
}
