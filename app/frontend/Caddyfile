{
    auto_https off
    http_port 8080
    https_port 8443
    admin 0.0.0.0:3003
    servers {
        metrics
    }
}
:8080 {
    root * /srv
    encode zstd gzip
    file_server
    
    # Fixed templates directive syntax
    // templates {
    //     path /env.js
    //     mime application/javascript
    //     delimiters "{$" "}"
    // }
    
    @spa_router {
        not path /gwells/api/v2/*
        file {
            try_files {path} /index.html
        }
    }
    
    rewrite @spa_router {http.matchers.file.relative}
    
    # API proxy configuration
    @api {
        path /api/*
    }
    handle @api {
        uri replace /api {$API_PATH}
        reverse_proxy {$API_HOST}
    }
}

:3001 {
    handle /health {
        respond "OK"
    }
}
