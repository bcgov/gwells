{
    auto_https off
    http_port 8080
    https_port 8443
    admin 0.0.0.0:3003
    servers {
        metrics
    }
}
{$AXIOS_BASE_URL:http://backend:8000/} {
    root * app/frontend/dist
    file_server
    templates
}
:8080 {
    root * /srv
    encode zstd gzip
    file_server
    @spa_router {
        not path /gwells/api/v2/*
        file {
            try_files {path} /index.html
        }
    }
    templates {
        mime application/javascript
        match /env.js
    }
    rewrite @spa_router {http.matchers.file.relative}
    
    # Updated reverse proxy configuration
    handle_path /api/* {
        uri strip_prefix /api
        uri path_prefix {$API_PATH}
        reverse_proxy {$API_HOST}
    }
}

:3001 {
    handle /health {
        respond "OK"
    }
}
