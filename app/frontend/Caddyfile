{
    auto_https off
    http_port 8080
    https_port 8443
    admin 0.0.0.0:3003
    servers {
        metrics
    }
}
{$VITE_BACKEND_URL:http://backend:8000/} {
    root * app/frontend/dist
    file_server
    templates
}
:8080 {
    root * /srv
    encode zstd gzip
    file_server
    
    @js_files {
        path *.js
    }
    header @js_files Content-Type "application/javascript"
    
    @spa_router {
        not path /gwells/api/v2/*
        file {
            try_files {path} /index.html
        }
    }
    templates {
        mime application/javascript
        match /env.js
    }
    rewrite @spa_router {http.matchers.file.relative}
    reverse_proxy /api* {$VITE_BACKEND_URL} {
    }
}
:3001 {
    handle /health {
        respond "OK"
    }
}
